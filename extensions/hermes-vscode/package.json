{
  "name": "hermes-vscode",
  "displayName": "Hermes",
  "description": "Run Hermes desktop games and open the live inspector in VS Code / Cursor.",
  "version": "0.1.0",
  "publisher": "hermes",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:game/hermes.json"],
  "main": "./lib/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hermes.runDesktop",
        "title": "Hermes: Run Desktop"
      },
      {
        "command": "hermes.openInspector",
        "title": "Hermes: Open Inspector"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p ."
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
