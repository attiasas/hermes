{
  "preload": {
    "bundles": ["game"],
    "async": true
  },
  "camera": {
    "version": 1,
    "projection": "perspective",
    "x": 0,
    "y": 0,
    "z": 5,
    "fieldOfView": 60,
    "fitMode": "stretch"
  },
  "inputContext": "gameplay",
  "ui": "ui/hud.json",
  "entities": [
    {
      "type": "spin-cube",
      "id": "cube",
      "components": {
        "FootstepEmitter": {
          "clips": ["footstep"],
          "clipIsId": true,
          "intervalSeconds": 0.4,
          "minSpeed": 0.3
        }
      }
    },
    {
      "type": "campfire",
      "id": "fire-pit",
      "components": {
        "Transform": { "x": 2, "y": 0, "z": -2 }
      }
    },
    {
      "id": "player-hp",
      "components": {
        "UiAttach": {
          "document": "ui/hp-bar.json",
          "follow": "cube",
          "offsetY": 2.2
        }
      }
    }
  ]
}
