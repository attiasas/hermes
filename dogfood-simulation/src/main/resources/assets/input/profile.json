{
  "version": 1,
  "context": "gameplay",
  "actions": {
    "select": { "type": "button" },
    "pause": { "type": "button" },
    "start_game": { "type": "button" },
    "resume": { "type": "button" },
    "quit": { "type": "button" },
    "camera_move_forward": { "type": "button" },
    "camera_move_backward": { "type": "button" },
    "camera_move_left": { "type": "button" },
    "camera_move_right": { "type": "button" },
    "camera_look_at_up": { "type": "button" },
    "camera_look_at_down": { "type": "button" },
    "camera_look_at_left": { "type": "button" },
    "camera_look_at_right": { "type": "button" },
    "camera_look_at_forward": { "type": "button" },
    "camera_look_at_backward": { "type": "button" }
  },
  "bindings": [
    { "action": "select", "source": "pointer", "button": "LEFT", "when": "justPressed", "context": "gameplay" },
    { "action": "pause", "source": "keyboard", "key": "ESCAPE", "when": "justPressed", "context": "gameplay" },
    { "action": "camera_move_forward", "source": "keyboard", "key": "W", "when": "pressed", "context": "gameplay" },
    { "action": "camera_move_backward", "source": "keyboard", "key": "S", "when": "pressed", "context": "gameplay" },
    { "action": "camera_move_left", "source": "keyboard", "key": "A", "when": "pressed", "context": "gameplay" },
    { "action": "camera_move_right", "source": "keyboard", "key": "D", "when": "pressed", "context": "gameplay" },
    { "action": "camera_look_at_up", "source": "keyboard", "key": "Q", "when": "pressed", "context": "gameplay" },
    { "action": "camera_look_at_down", "source": "keyboard", "key": "E", "when": "pressed", "context": "gameplay" },
    { "action": "camera_look_at_forward", "source": "keyboard", "key": "UP", "when": "pressed", "context": "gameplay" },
    { "action": "camera_look_at_backward", "source": "keyboard", "key": "DOWN", "when": "pressed", "context": "gameplay" },
    { "action": "camera_look_at_left", "source": "keyboard", "key": "LEFT", "when": "pressed", "context": "gameplay" },
    { "action": "camera_look_at_right", "source": "keyboard", "key": "RIGHT", "when": "pressed", "context": "gameplay" },
    { "action": "start_game", "source": "keyboard", "key": "ENTER", "when": "justPressed", "context": "menu" },
    { "action": "start_game", "source": "keyboard", "key": "SPACE", "when": "justPressed", "context": "menu" },
    { "action": "resume", "source": "keyboard", "key": "ENTER", "when": "justPressed", "context": "menu" },
    { "action": "resume", "source": "keyboard", "key": "ESCAPE", "when": "justPressed", "context": "menu" },
    { "action": "quit", "source": "keyboard", "key": "Q", "when": "justPressed", "context": "menu" }
  ],
  "gamepad": { "deadzone": 0.15 }
}
