{
  "preload": {
    "bundles": ["boot"],
    "async": false
  },
  "camera": {
    "version": 1,
    "projection": "orthographic",
    "x": 320,
    "y": 240,
    "z": 1,
    "zoom": 1
  },
  "entities": [
    {
      "id": "logo",
      "components": {
        "Transform": {
          "x": 320,
          "y": 240,
          "z": 2,
          "scaleX": 0.35,
          "scaleY": 0.35
        },
        "Drawables": {
          "sprite": "hermes-logo.png"
        },
        "Material": {
          "shader": "default/unlit"
        },
        "PulseMarker": {
          "amplitude": 0.15,
          "speed": 2.5
        },
        "Selectable": {
          "radius": 48,
          "layer": "WORLD"
        }
      }
    },
    {
      "id": "marker",
      "components": {
        "Transform": {
          "x": 180,
          "y": 180,
          "z": 2,
          "scaleX": 0.35,
          "scaleY": 0.35
        },
        "Drawables": {
          "sprite": "hermes-logo.png"
        },
        "Material": {
          "shader": "default/unlit"
        },
        "Selectable": {
          "radius": 48,
          "layer": "WORLD"
        }
      }
    }
  ]
}
